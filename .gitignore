# ---- TRACE telemetry (local, ephemeral, never committed) ----
agent-logs/*.db
agent-logs/*.db-wal
agent-logs/*.db-shm
agent-logs/*.db-journal
agent-logs/*.jsonl
agent-logs/context.json
.trace-initialized

# Per-project config generated by the setup wizard (ship project.example.json instead)
agent-context/project.json

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/

# ---- Node / Vite ----
node_modules/
dist/
.vite/
*.local
vite.config.js.timestamp-*.mjs
vite.config.*.timestamp-*

# ---- Env & secrets ----
.env
.env.*
!.env.example

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---- Claude Code local overrides ----
.claude/settings.local.json
